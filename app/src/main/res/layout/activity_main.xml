<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    tools:context=".MainActivity"
    tools:targetApi="33"
    tools:theme="@style/Theme.WashNotif">

    <TextView
        android:id="@+id/deviceNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#666666"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:text="@string/device_name_default" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:text="@string/status_communicating" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_app_settings"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_interval"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lines="2"
                    android:layout_marginBottom="4dp"/>
                <NumberPicker
                    android:id="@+id/intervalPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cooldown"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lines="2"
                    android:layout_marginBottom="4dp"/>
                <NumberPicker
                    android:id="@+id/cooldownPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_volume"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lines="2"
                    android:layout_marginBottom="4dp"/>
                <NumberPicker
                    android:id="@+id/volumePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/saveSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/button_update_settings"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/unlockButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/button_force_unlock"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B71C1C"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/exitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/button_exit_app"
            android:textColor="#FFFFFF"
            android:backgroundTint="#455A64"
            android:textSize="16sp" />

        <!-- メニューから遷移できるため、このボタンは非表示にします -->
        <Button
            android:id="@+id/settingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/button_open_token_settings"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="16sp"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</LinearLayout>