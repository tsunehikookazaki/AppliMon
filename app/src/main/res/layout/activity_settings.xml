<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".SettingsActivity"
    tools:targetApi="35"
    tools:theme="@style/Theme.WashNotif">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="60dp">

        <!-- 機器1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_device1_section"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_device_display_name"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/deviceNameInput1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_device_display_name"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="deviceName"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_device_id"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/deviceIdInput1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_device_id"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_start_phrase"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/startPhraseInput1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_start_phrase"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_end_phrase"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/phraseInput1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_end_phrase"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <!-- 機器2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_device2_section"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_device_display_name"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/deviceNameInput2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_device_display_name"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="deviceName"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_device_id"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/deviceIdInput2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_device_id"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_start_phrase"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/startPhraseInput2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_start_phrase"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_end_phrase"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/phraseInput2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="400dp"
            android:minHeight="48dp"
            android:hint="@string/hint_end_phrase"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:autofillHints="none"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:text="@string/button_save_settings"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/developerSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:text="@string/button_api_settings"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
